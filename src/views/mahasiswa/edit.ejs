<div class="bg-white p-6 rounded-2xl shadow max-w-lg">
  <h2 class="text-xl font-bold mb-4">Edit Mahasiswa</h2>
  <form action="/mahasiswa/update/<%= mhs.id %>" method="POST">
    <input name="nama" value="<%= mhs.nama %>" class="w-full mb-3 p-2 border rounded" required />
    <input name="nim" value="<%= mhs.nim %>" class="w-full mb-3 p-2 border rounded" required />
    <div class="flex gap-3"><button class="bg-yellow-500 text-white px-4 py-2 rounded">Update</button><a href="/mahasiswa" class="bg-gray-400 text-white px-4 py-2 rounded">Kembali</a></div>
  </form>
</div>
