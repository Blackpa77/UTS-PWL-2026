<div class="bg-white p-6 rounded-2xl shadow max-w-lg">
  <h2 class="text-xl font-bold mb-4">Tambah Mahasiswa</h2>
  <form action="/mahasiswa" method="POST">
    <input name="nama" placeholder="Nama" class="w-full mb-3 p-2 border rounded" required />
    <input name="nim" placeholder="NIM" class="w-full mb-3 p-2 border rounded" required />
    <div class="flex gap-3"><button class="bg-blue-500 text-white px-4 py-2 rounded">Simpan</button><a href="/mahasiswa" class="bg-gray-400 text-white px-4 py-2 rounded">Kembali</a></div>
  </form>
</div>
